<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="714.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.controller.MainViewController">
   <top>
      <VBox prefHeight="59.0" prefWidth="714.0" BorderPane.alignment="CENTER">
         <children>
            <Label alignment="CENTER" prefHeight="34.0" prefWidth="714.0" text="System Zarządzania Flotą Pojazdów">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>
            <MenuBar>
              <menus>
                <Menu fx:id="vechicleMenu" disable="true" mnemonicParsing="false" onAction="#handlePojazdScene" text="Pojazdy" />
                <Menu fx:id="driversMenu" mnemonicParsing="false" onAction="#handleKierowcyScene" text="Kierowcy" />
                <Menu fx:id="serviceMenu" mnemonicParsing="false" onAction="#handleSerwiceScene" text="Serwis" />
              </menus>
            </MenuBar>
         </children>
      </VBox>
   </top>
   <center>
      <TableView prefHeight="296.0" prefWidth="694.0" BorderPane.alignment="CENTER">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="25.0" text="ID" />
          <TableColumn fx:id="brandColumn" prefWidth="98.0" text="Marka" />
          <TableColumn fx:id="modelColumn" prefWidth="111.0" text="Model" />
            <TableColumn fx:id="yearColumn" prefWidth="83.0" text="Rok Produkcji" />
            <TableColumn fx:id="rejestrationColumn" prefWidth="105.0" text="NR Rejestracyjny" />
            <TableColumn fx:id="bodyColumn" prefWidth="90.0" text="Typ Nadwozia" />
            <TableColumn fx:id="inspectionColumn" prefWidth="128.0" text="Przegląd Techniczny" />
            <TableColumn fx:id="detailsColumn" prefWidth="73.0" text="Uwagi" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </center>
   <bottom>
      <HBox alignment="CENTER_RIGHT" prefHeight="45.0" prefWidth="714.0" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#handleAddVechicle" text="Dodaj Pojazd">
               <HBox.margin>
                  <Insets left="10.0" right="10.0" />
               </HBox.margin></Button>
            <Button fx:id="editButton" disable="true" mnemonicParsing="false" onAction="#handleEditVechicle" text="Edytuj Pojzd">
               <HBox.margin>
                  <Insets left="10.0" right="10.0" />
               </HBox.margin></Button>
            <Button fx:id="deleteButton" disable="true" mnemonicParsing="false" onAction="#handleDeleteVechicle" text="Usuń Pojazd">
               <HBox.margin>
                  <Insets left="10.0" right="10.0" />
               </HBox.margin></Button>
            <Button alignment="BOTTOM_RIGHT" contentDisplay="RIGHT" mnemonicParsing="false" onAction="#handleRefresh" text="Odśwież">
               <HBox.margin>
                  <Insets left="10.0" right="10.0" />
               </HBox.margin></Button>
         </children>
      </HBox>
   </bottom>
</BorderPane>
